<div class="max-w-md mx-auto mt-8 p-6 bg-white rounded-lg shadow-md">
  <h1 class="text-2xl font-bold mb-6 text-gray-900">Sign Up</h1>

  <%= form_with model: @user, url: signup_path, method: :post, local: true do |form| %>
    <% if @user.errors.any? %>
      <div class="mb-4 p-4 bg-red-50 border border-red-200 rounded-md">
        <h2 class="text-sm font-medium text-red-800 mb-2"><%= pluralize(@user.errors.count, "error") %> prohibited this account from being saved:</h2>
        <ul class="list-disc list-inside text-sm text-red-700">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-4">
      <%= form.label :email, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.email_field :email, required: true, autofocus: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
    </div>

    <div class="mb-4">
      <%= form.label :preferred_location, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_field :preferred_location, required: true, placeholder: "e.g., San Francisco, CA", class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
    </div>

    <div class="mb-4">
      <%= form.label :password, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.password_field :password, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
    </div>

    <div class="mb-6">
      <%= form.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.password_field :password_confirmation, required: true, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
    </div>

    <div class="mb-4 flex items-center">
      <%= form.check_box :is_artist, class: "h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" %>
      <%= form.label :is_artist, "I am an artist", class: "ml-2 text-sm text-gray-700" %>
    </div>

    <div class="mb-6">
      <%= form.submit "Sign Up", class: "w-full px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 transition-colors cursor-pointer" %>
    </div>
  <% end %>

  <p class="text-sm text-gray-600 text-center">
    Already have an account? <%= link_to "Log in", login_path, class: "text-indigo-600 hover:text-indigo-700 font-medium" %>
  </p>
</div>
