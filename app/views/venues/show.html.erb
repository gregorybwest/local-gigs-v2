<div class="max-w-2xl mx-auto mt-8">
  <div class="bg-white rounded-lg shadow-md p-6">
    <h1 class="text-3xl font-bold text-gray-900 mb-4"><%= @venue.name %></h1>
    <div class="space-y-2 text-gray-700 mb-6">
      <p class="text-lg"><%= @venue.address %></p>
      <p class="text-lg"><%= @venue.city %></p>
    </div>

    <div class="border-t pt-6">
      <h2 class="text-2xl font-semibold text-gray-900 mb-4">Events at this venue</h2>
      <% if @events.any? %>
        <div class="space-y-4">
          <% @events.each do |event| %>
            <div class="border-l-4 border-blue-500 pl-4 py-2">
              <div class="font-medium text-gray-900">
                <%= link_to event.name.presence || "Untitled Event", event_path(event), class: "text-blue-600 hover:text-blue-700 hover:underline" %>
              </div>
              <div class="text-sm text-gray-600 mt-1">
                <%= event.formatted_show_time %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500 italic">No events scheduled at this venue yet.</p>
      <% end %>
    </div>
  </div>
</div>
