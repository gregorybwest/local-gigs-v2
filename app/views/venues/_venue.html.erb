<div id="<%= dom_id venue %>" class="bg-white dark:bg-gray-800 rounded-lg shadow-md hover:shadow-xl dark:hover:shadow-indigo-500/20 transition-all duration-200 p-6 mb-4 border border-gray-200 dark:border-gray-700">
  <div class="space-y-3">
    <div>
      <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-1">
        <%= link_to venue.name, venue, class: "text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 hover:underline" %>
      </h3>
    </div>

    <div class="flex items-center text-gray-700 dark:text-gray-300">
      <svg class="w-5 h-5 mr-2 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
      </svg>
      <span><%= venue.address %>, <%= venue.city %></span>
    </div>

    <% upcoming_count = venue.events.upcoming.count %>
    <% if upcoming_count > 0 %>
      <div class="flex items-center text-gray-700 dark:text-gray-300">
        <svg class="w-5 h-5 mr-2 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
        </svg>
        <span><%= pluralize(upcoming_count, "upcoming event") %></span>
      </div>
    <% end %>
  </div>
</div>
