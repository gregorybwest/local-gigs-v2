<div data-controller="mobile-menu">
<nav class="flex items-center justify-between px-6 md:px-16 lg:px-24 xl:px-32 py-4 border-b border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 relative transition-all">
    <a href="/" class="text-2xl font-bold text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 transition-colors duration-200">
  Local Gigs
</a>

    <div class="flex items-center gap-8 sm:hidden">
        <button aria-label="Search" data-action="click->mobile-menu#toggleSearch" class="text-gray-600 dark:text-gray-300">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                <circle cx="11" cy="11" r="7"/>
                <line x1="16.5" y1="16.5" x2="22" y2="22"/>
            </svg>
        </button>
        <button aria-label="Menu" data-action="click->mobile-menu#toggle" class="text-gray-600 dark:text-gray-300">
            <svg width="21" height="15" viewBox="0 0 21 15" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="21" height="1.5" rx=".75" fill="currentColor"/>
                <rect x="8" y="6" width="13" height="1.5" rx=".75" fill="currentColor"/>
                <rect x="6" y="13" width="15" height="1.5" rx=".75" fill="currentColor"/>
            </svg>
        </button>
    </div>

    <div data-mobile-menu-target="menu" class="hidden absolute top-[60px] right-0 bg-white dark:bg-gray-800 shadow-lg rounded-lg py-4 flex-col items-end gap-2 px-5 text-sm md:hidden opacity-0 scale-95 transition-all duration-200 ease-out origin-top-right border border-gray-200 dark:border-gray-700">
        <a href="/" class="block py-2 text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Home</a>
        <a href="/events" class="block py-2 text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Events</a>
        <%= link_to "New Event", new_event_path, class: "px-4 py-2 rounded-full text-white font-medium transition-all hover:opacity-90", style: "background-color: #006D77;" %>
        <% if logged_in? %>
          <%= link_to "Logout", logout_path, data: { turbo_method: :delete }, class: "block py-2 font-bold text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %>
        <% else %>
          <%= link_to "Login", login_path, class: "block py-2 font-bold text-gray-700 dark:text-gray-300 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %>
        <% end %>
    </div>

    <div class="hidden sm:flex items-center gap-8 text-gray-700 dark:text-gray-300">
        <a href="/" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Home</a>
        <a href="/events" class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">Events</a>
        <%= link_to "New Event", new_event_path, class: "px-6 py-2 rounded-full text-white font-medium transition-all hover:opacity-90 shadow-md", style: "background-color: #006D77;" %>

        <div class="hidden lg:flex" data-controller="global-search">
            <div class="relative w-64">
                <div class="flex items-center text-sm gap-2 border border-gray-300 dark:border-gray-600 px-3 rounded-full bg-gray-100 dark:bg-gray-700">
                    <input data-global-search-target="input"
                           data-action="input->global-search#search keydown->global-search#dismiss"
                           class="py-1.5 w-full bg-transparent outline-none placeholder-gray-400 text-gray-700 dark:text-gray-300"
                           type="text"
                           placeholder="Search events & venues"
                           autocomplete="off" />
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M10.836 10.615 15 14.695" stroke="#7A7B7D" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path clip-rule="evenodd" d="M9.141 11.738c2.729-1.136 4.001-4.224 2.841-6.898S7.67.921 4.942 2.057C2.211 3.193.94 6.281 2.1 8.955s4.312 3.92 7.041 2.783" stroke="#7A7B7D" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <div data-global-search-target="results"
                     class="hidden absolute top-full left-0 mt-1 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-lg z-50 max-h-96 overflow-y-auto"
                     style="width: 340px;">
                </div>
            </div>
        </div>

        <% if logged_in? %>
          <%= link_to "Logout", logout_path, data: { turbo_method: :delete }, class: "cursor-pointer px-8 py-2 bg-indigo-500 hover:bg-indigo-600 transition text-white rounded-full" %>
        <% else %>
          <%= link_to "Login", login_path, class: "cursor-pointer px-8 py-2 bg-indigo-500 hover:bg-indigo-600 transition text-white rounded-full" %>
        <% end %>
    </div>
</nav>

<div data-mobile-menu-target="searchPanel"
     class="hidden bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 px-4 py-3"
     data-controller="global-search">
    <div class="flex items-center text-sm gap-2 border border-gray-300 dark:border-gray-600 px-3 rounded-full bg-gray-100 dark:bg-gray-700">
        <input data-global-search-target="input"
               data-action="input->global-search#search keydown->global-search#dismiss"
               class="py-1.5 w-full bg-transparent outline-none placeholder-gray-400 text-gray-700 dark:text-gray-300"
               type="text"
               placeholder="Search events & venues"
               autocomplete="off" />
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-500 dark:text-gray-400">
            <circle cx="11" cy="11" r="7"/>
            <line x1="16.5" y1="16.5" x2="22" y2="22"/>
        </svg>
    </div>
    <div data-global-search-target="results"
         class="hidden mt-2 w-full bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-lg max-h-64 overflow-y-auto">
    </div>
</div>
</div>
