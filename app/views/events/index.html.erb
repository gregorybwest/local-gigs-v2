<% content_for :title, "Events" %>

<% content_for :head do %>
  <link href="https://api.mapbox.com/mapbox-gl-js/v3.18.0/mapbox-gl.css" rel="stylesheet">
  <script src="https://api.mapbox.com/mapbox-gl-js/v3.18.0/mapbox-gl.js"></script>
<% end %>

<div class="w-full mt-[10px]">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 dark:bg-green-900 mb-5 text-green-700 dark:text-green-300 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <!-- Mapbox Map -->
  <div id="map" class="w-full shadow-lg mb-8 rounded-xl overflow-hidden" style="height: 450px;"></div>

  <div id="events" class="space-y-4">
    <% if @events.any? %>
      <% @events.each do |event| %>
        <%= render event %>
      <% end %>
    <% else %>
      <p class="text-center my-10 text-gray-600 dark:text-gray-400">No events found.</p>
    <% end %>
  </div>
</div>

<%= content_tag :div, id: "events-data", data: {
  events: @events.select { |e| e.venue&.longitude && e.venue&.latitude }.map { |e|
    {
      id: e.id,
      name: e.name,
      venue_name: e.venue.name,
      venue_id: e.venue.id,
      show_time: e.formatted_show_time,
      latitude: e.venue.latitude,
      longitude: e.venue.longitude,
      url: event_path(e)
    }
  }.to_json
} do %>
<% end %>

<script>
  function initializeMap() {
    if (typeof mapboxgl === 'undefined') {
      console.error('Mapbox GL JS not loaded');
      return;
    }

    const mapContainer = document.getElementById('map');
    if (!mapContainer) return;

    if (mapContainer._mapboxMap) {
      mapContainer._mapboxMap.remove();
      mapContainer._mapboxMap = null;
    }

    mapboxgl.accessToken = '<%= Rails.application.credentials.mapbox&.[](:access_token) %>';

    const eventsDataEl = document.getElementById('events-data');
    const events = eventsDataEl ? JSON.parse(eventsDataEl.dataset.events || '[]') : [];

    const fallbackCenter = [-98.5795, 39.8283];
    const defaultZoom = 9;

    function createMap(center) {
      const map = new mapboxgl.Map({
        container: 'map',
        style: 'mapbox://styles/mapbox/standard',
        zoom: defaultZoom,
        center: center
      });

      mapContainer._mapboxMap = map;
      map.addControl(new mapboxgl.NavigationControl());
      map.on('load', () => addEventMarkers(map));
      return map;
    }

    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        (position) => {
          createMap([position.coords.longitude, position.coords.latitude]);
        },
        () => {
          createMap(fallbackCenter);
        },
        { timeout: 5000 }
      );
    } else {
      createMap(fallbackCenter);
    }

    // Add event markers to the map
    function addEventMarkers(map) {
      const bounds = new mapboxgl.LngLatBounds();
      let hasMarkers = false;

      events.forEach(event => {
        if (event.longitude && event.latitude) {
          const lngLat = [event.longitude, event.latitude];

          const popup = new mapboxgl.Popup({ offset: 25 }).setHTML(`
            <div>
              <p class="popup-title">${event.name || event.venue_name}</p>
              <p class="popup-venue"><a href="/venues/${event.venue_id}">${event.venue_name}</a></p>
              <p class="popup-time">${event.show_time}</p>
              <a href="${event.url}" class="popup-link">View Event &rarr;</a>
            </div>
          `);

          new mapboxgl.Marker({ color: '#006D77' })
            .setLngLat(lngLat)
            .setPopup(popup)
            .addTo(map);

          bounds.extend(lngLat);
          hasMarkers = true;
        }
      });

      // If we have event markers, fit the map to show all of them
      if (hasMarkers) {
        map.fitBounds(bounds, { padding: 60, maxZoom: 13, duration: 1500 });
        return;
      }

    }
  }

  // Initialize map on both turbo:load (full page load) and turbo:render (cache restoration)
  document.addEventListener('turbo:load', initializeMap);
  document.addEventListener('turbo:render', initializeMap);

  // Clean up map before Turbo caches the page
  document.addEventListener('turbo:before-cache', () => {
    const mapContainer = document.getElementById('map');
    if (mapContainer && mapContainer._mapboxMap) {
      mapContainer._mapboxMap.remove();
      mapContainer._mapboxMap = null;
    }
  });
</script>
