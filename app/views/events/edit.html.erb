<% content_for :title, "Editing event" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-4xl text-gray-900 dark:text-white">Editing event</h1>

  <%= render "form", event: @event %>

  <%= link_to "Show this event", @event, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 text-gray-900 dark:text-gray-200 inline-block font-medium" %>
  <%= link_to "Back to events", events_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 text-gray-900 dark:text-gray-200 inline-block font-medium" %>
</div>
