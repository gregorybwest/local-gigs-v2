<div id="<%= dom_id event %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Event Name:</strong>
    <%= link_to (event.name.presence || "Untitled Event"), event, class: "text-blue-600 hover:text-blue-700 hover:underline" %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Venue:</strong>
    <% if event.venue %>
      <%= link_to event.venue.name, venue_path(event.venue), class: "text-blue-600 hover:text-blue-700 hover:underline" %>
    <% else %>
      <%= event.mapbox_id %>
    <% end %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Show time:</strong>
    <%= event.formatted_show_time %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Flier image url:</strong>
    <%= event.flier_image_url %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Ticket link url:</strong>
    <%= event.ticket_link_url %>
  </div>
  <div>
    <strong class="block font-medium mb-1">User:</strong>
    <%= event.user_id %>
  </div>
</div>
